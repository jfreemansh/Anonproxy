# Copy to .env and edit per engagement.  `python -m anonproxy wizard` writes this for you.

# Change this PER CLIENT — it isolates the surrogate vault.
ENGAGEMENT_ID=default

# Engagement scope seed (recommended): client domains/hostnames/org names that
# must ALWAYS be anonymized — including bare hostnames regex can't infer (DC01).
# Comma-separated; optional "value=TYPE". Or point ANONPROXY_SCOPE_FILE at a file.
ANONPROXY_SCOPE=
ANONPROXY_SCOPE_FILE=

# Detector chain (regex floor always runs regardless). gliner2 catches
# general PII (email/phone/bank/passport/credentials) fast and in-process;
# ollama additionally catches bare hostnames, org names, and person names,
# which gliner2's fixed PII taxonomy doesn't cover.
ANONPROXY_DETECTORS=regex,gliner2,ollama

# Local detection model (regex always runs; the LLM adds recall for prose).
LLM_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Proxy listen address (keep on localhost for an all-local setup).
HOST=127.0.0.1
PORT=8080

# Upstreams (leave as defaults unless you route through a gateway).
ANTHROPIC_UPSTREAM=https://api.anthropic.com
OPENAI_UPSTREAM=https://api.openai.com

# Optional: require this token (header X-Anonproxy-Token or ?token=) on the
# engine API and audit data endpoints.  Recommended if other local apps could
# reach the port.
ANONPROXY_API_TOKEN=

# Set to 1 to keep the vault in memory only (nothing written to disk).
ANONPROXY_EPHEMERAL=0

# Set to false to disable the /audit dashboard entirely.
ANONPROXY_AUDIT=true
